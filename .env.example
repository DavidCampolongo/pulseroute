POSTGRES_DB=pulseroute
POSTGRES_USER=pulseroute
POSTGRES_PASSWORD=replace_with_local_development_password
POSTGRES_PORT=5432

NODE_ENV=development
API_HOST=127.0.0.1
API_PORT=3000
LOG_LEVEL=debug

DATABASE_URL=postgresql://pulseroute:replace_with_local_development_password@localhost:5432/pulseroute

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Local-only password used to hash seeded development users.
# Set a real value in .env; never commit it.
SEED_USER_PASSWORD=
