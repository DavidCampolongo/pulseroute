{
  "name": "pulseroute",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "db:validate": "pnpm --filter @pulseroute/db run db:validate",
    "db:format": "pnpm --filter @pulseroute/db run db:format",
    "db:generate": "pnpm --filter @pulseroute/db run db:generate",
    "db:migrate:dev": "pnpm --filter @pulseroute/db run db:migrate:dev",
    "db:migrate:deploy": "pnpm --filter @pulseroute/db run db:migrate:deploy",
    "db:migrate:reset": "pnpm --filter @pulseroute/db run db:migrate:reset",
    "db:studio": "pnpm --filter @pulseroute/db run db:studio"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.12.0"
    }
  },
  "type": "module",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.13.3",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0"
  },
  "volta": {
    "node": "24.18.0"
  }
}
